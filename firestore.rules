rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // الزبون يقدر بس "يضيف" طلب جديد، ما يقدر يشوف أو يعدّل طلبات غيره
    // صاحب الكافتيريا (بعد تسجيل الدخول) بس يقدر يشوف/يعدّل/يحذف الطلبات
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // عداد رقم الطلب التسلسلي — لازم يكون مفتوح للزبون عشان ياخذ رقم طلبه
    match /meta/{docId} {
      allow read, write: if true;
    }
  }
}
